{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aodcast.dev/schemas/session.schema.json",
  "title": "Session",
  "type": "object",
  "required": [
    "session_id",
    "topic",
    "creation_intent",
    "state",
    "deleted_at",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "session_id": { "type": "string" },
    "topic": { "type": "string", "minLength": 1 },
    "creation_intent": { "type": "string", "minLength": 1 },
    "state": {
      "type": "string",
      "enum": [
        "topic_defined",
        "interview_in_progress",
        "readiness_evaluation",
        "ready_to_generate",
        "script_generated",
        "script_edited",
        "audio_rendering",
        "completed",
        "failed"
      ]
    },
    "llm_provider": { "type": "string" },
    "tts_provider": { "type": "string" },
    "last_error": { "type": "string" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "memory_mode": { "type": "string", "enum": ["enabled", "disabled"] },
    "memory_processed_through_turn_id": { "type": "string" },
    "authorized_memory_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "memory_usage_events": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["operation", "memory_ids", "used_at"],
        "properties": {
          "operation": { "type": "string" },
          "memory_ids": { "type": "array", "items": { "type": "string" } },
          "used_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
