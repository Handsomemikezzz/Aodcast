{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aodcast.dev/schemas/bridge-request-state.schema.json",
  "title": "BridgeRequestState",
  "type": "object",
  "required": ["operation", "phase", "progress_percent", "message"],
  "properties": {
    "operation": { "type": "string", "minLength": 1 },
    "phase": {
      "type": "string",
      "enum": ["running", "cancelling", "succeeded", "failed", "cancelled"]
    },
    "progress_percent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "message": { "type": "string" },
    "run_token": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "audio_path": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "settings": {
      "type": "object",
      "properties": {
        "voice_id": { "type": "string" },
        "voice_name": { "type": "string" },
        "style_id": { "type": "string" },
        "style_name": { "type": "string" },
        "speed": { "type": "number" },
        "language": { "type": "string" },
        "audio_format": { "type": "string" },
        "preview_text": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
