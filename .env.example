# Aodcast optional local environment variables.
# The app primarily stores provider settings through the local config UI/CLI.
# Never commit a real .env file or real provider credentials.

# Optional parent folder for Aodcast model downloads (highest priority override).
AODCAST_HF_MODEL_BASE=""

# Optional Hugging Face cache root used by huggingface_hub (matches Voicebox behavior).
HF_HUB_CACHE="$HOME/.cache/huggingface/hub"

# Optional Hugging Face token if a model repository requires authentication.
HF_TOKEN=""
